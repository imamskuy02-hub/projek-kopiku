// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  slug      String     @unique
  menuItems MenuItem[]
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Int      // Price in IDR (e.g., 28000 for Rp 28.000)
  image       String?  // Path or external URL
  available   Boolean  @default(true)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Order {
  id            Int      @id @default(autoincrement())
  customerName  String
  tableNumber   String
  notes         String?  @db.Text
  paymentMethod String   // "CASH", "TRANSFER", "QRIS"
  totalAmount   Int
  status        String   // "PENDING", "PAID", "COMPLETED", "CANCELLED"
  items         String   @db.Text // Stringified JSON array of items
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

